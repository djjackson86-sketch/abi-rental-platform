# ABI Rental Platform environment
# Copy to .env for local use. Do not commit real secrets.

FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@abi.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password
DATABASE_PATH=instance/abi_rental.db
PORT=5057

# Server-side Telegram notifications. Keep real values in Render/local env only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CRON_SECRET=
TELEGRAM_NOTIFICATIONS_ENABLED=false
PUBLIC_BASE_URL=http://localhost:5057
BUSINESS_TIMEZONE=Africa/Johannesburg

# Production/Render notes:
# - FLASK_ENV=production requires SECRET_KEY and ADMIN_PASSWORD to be non-default.
# - render.yaml uses generated values for SECRET_KEY and ADMIN_PASSWORD.
# - DATABASE_PATH should point at a persistent disk path on Render, e.g. /var/data/abi_rental.db.
